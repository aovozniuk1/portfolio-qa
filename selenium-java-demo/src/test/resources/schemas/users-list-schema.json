{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Users List Response",
  "description": "Schema for GET /users response from jsonplaceholder.typicode.com",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "username", "email"],
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string" },
      "username": { "type": "string" },
      "email": { "type": "string" },
      "phone": { "type": "string" },
      "website": { "type": "string" },
      "address": { "type": "object" },
      "company": { "type": "object" }
    }
  }
}
