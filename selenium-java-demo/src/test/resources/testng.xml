<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium Demo Suite" parallel="methods" thread-count="2" verbose="2">

    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <test name="UI - Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DynamicControlsTest"/>
            <class name="tests.DropdownTest"/>
            <class name="tests.TablesTest"/>
            <class name="tests.JavaScriptAlertsTest"/>
            <class name="tests.IframeTest"/>
            <class name="tests.HoversTest"/>
            <class name="tests.WindowsTest"/>
            <class name="tests.FileUploadTest"/>
        </classes>
    </test>

    <test name="UI - Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.DynamicControlsTest"/>
            <class name="tests.DropdownTest"/>
            <class name="tests.TablesTest"/>
            <class name="tests.JavaScriptAlertsTest"/>
            <class name="tests.IframeTest"/>
            <class name="tests.HoversTest"/>
            <class name="tests.WindowsTest"/>
            <class name="tests.FileUploadTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="api.UserApiTest"/>
            <class name="api.PostApiTest"/>
        </classes>
    </test>

    <test name="CDP Tests">
        <parameter name="chrome.only" value="true"/>
        <classes>
            <class name="cdp.CdpNetworkTest"/>
        </classes>
    </test>

</suite>
